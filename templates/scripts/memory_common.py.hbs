#!/usr/bin/env python3
"""Shared helpers for local Markdown memory."""

from __future__ import annotations

import argparse
import hashlib
import math
import re
import sqlite3
from pathlib import Path


ROOT = Path(__file__).resolve().parents[2]
DB_PATH = ROOT / ".memory" / "agent-memory.sqlite3"
VECTOR_DIMS = 64

INCLUDE_PATTERNS = (
    ".agentic-scaffold/BUSINESS_LOGIC.md",
    "AGENTS.md",
    "CLAUDE.md",
    ".agentic-scaffold/docs/**/*.md",
    ".agentic-scaffold/.scratchpad/**/*.md",
    ".agentic-scaffold/.history/**/*.md",
)


def connect(db_path: Path = DB_PATH) -> sqlite3.Connection:
    db_path.parent.mkdir(parents=True, exist_ok=True)
    conn = sqlite3.connect(db_path)
    conn.execute("pragma journal_mode=wal")
    return conn


def try_load_sqlite_vec(conn: sqlite3.Connection) -> bool:
    try:
        import sqlite_vec  # type: ignore
        conn.enable_load_extension(True)
        sqlite_vec.load(conn)
        conn.enable_load_extension(False)
        return True
    except Exception:
        conn.enable_load_extension(False)
        return False


def init_schema(conn: sqlite3.Connection) -> bool:
    has_vec = try_load_sqlite_vec(conn)
    conn.executescript(
        """
        create table if not exists chunks (
          id integer primary key,
          path text not null,
          heading text not null,
          chunk_index integer not null,
          content text not null,
          embedding text not null,
          content_hash text not null unique
        );
        create virtual table if not exists chunks_fts using fts5(
          content,
          heading,
          path unindexed,
          content='chunks',
          content_rowid='id'
        );
        """
    )
    if has_vec:
        conn.execute(
            f"create virtual table if not exists chunk_vec using vec0(embedding float[{VECTOR_DIMS}])"
        )
    return has_vec


def markdown_files() -> list[Path]:
    files: set[Path] = set()
    for pattern in INCLUDE_PATTERNS:
        files.update(ROOT.glob(pattern))
    return sorted(path for path in files if path.is_file())


def split_markdown(path: Path, text: str) -> list[tuple[str, str]]:
    chunks: list[tuple[str, str]] = []
    current_heading = path.as_posix()
    current: list[str] = []
    for line in text.splitlines():
        if line.startswith("#") and current:
            chunks.append((current_heading, "\n".join(current).strip()))
            current = []
        if line.startswith("#"):
            current_heading = line.strip("# ").strip() or path.as_posix()
        current.append(line)
    if current:
        chunks.append((current_heading, "\n".join(current).strip()))
    return [(heading, body) for heading, body in chunks if body]


TOKEN_RE = re.compile(r"[a-z0-9_]+", re.I)


def tokens(text: str) -> list[str]:
    return [token.lower() for token in TOKEN_RE.findall(text)]


def embedding(text: str) -> list[float]:
    vector = [0.0] * VECTOR_DIMS
    for token in tokens(text):
        digest = hashlib.blake2b(token.encode("utf-8"), digest_size=8).digest()
        slot = int.from_bytes(digest[:4], "little") % VECTOR_DIMS
        sign = 1.0 if digest[4] % 2 == 0 else -1.0
        vector[slot] += sign
    norm = math.sqrt(sum(value * value for value in vector)) or 1.0
    return [value / norm for value in vector]


def serialize_vector(values: list[float]) -> str:
    return "[" + ",".join(f"{value:.6f}" for value in values) + "]"


def cosine(left: list[float], right: list[float]) -> float:
    return sum(a * b for a, b in zip(left, right))


def parse_vector(value: str) -> list[float]:
    return [float(part) for part in value.strip("[]").split(",") if part]


def content_hash(path: Path, chunk_index: int, content: str) -> str:
    raw = f"{path.relative_to(ROOT)}\0{chunk_index}\0{content}".encode("utf-8")
    return hashlib.sha256(raw).hexdigest()


def add_db_argument(parser: argparse.ArgumentParser) -> None:
    parser.add_argument("--db", type=Path, default=DB_PATH, help="SQLite memory DB path")


def rel(path: Path) -> str:
    return path.relative_to(ROOT).as_posix()
