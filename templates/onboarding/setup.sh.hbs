#!/usr/bin/env bash
set -euo pipefail

echo "=== Setting up {{projectName}} ==="

{{#if packageManager}}
# Install dependencies
echo "Installing dependencies..."
{{packageManager}} install

{{/if}}
{{^packageManager}}
# Install dependencies
echo "Installing dependencies..."
npm install

{{/packageManager}}
# Copy env file if it exists
if [ -f .env.example ] && [ ! -f .env ]; then
  cp .env.example .env
  echo "Created .env from .env.example"
fi

echo "=== Setup complete ==="
